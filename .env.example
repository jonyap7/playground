# Optional cloud sync (Supabase). Leave blank to run on localStorage only.
# 1) Create a project at https://supabase.com
# 2) Run supabase/schema.sql in the SQL editor
# 3) Copy your project URL + anon key below (and into Vercel env vars)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Devices sharing the same room code see each other's jobs/applications/chat.
NEXT_PUBLIC_GIG_ROOM=demo
